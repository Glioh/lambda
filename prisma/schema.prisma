// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id String @id @default(uuid())
  name String
  userId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
  runs Run[]
  artifact Artifact?

}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  RESULT
  ERROR
}

model Message {
  id String @id @default(uuid())
  content String
  role MessageRole
  type MessageType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fragment Fragment?
  runs Run[]
}

model Fragment {
  id String @id @default(uuid())
  messageId String @unique
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  sandboxUrl String
  title String
  files Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model Usage {
  key String @id
  points Int
  expire DateTime?
}

enum RunStatus {
  waiting_confirmation
  confirmed
  dispatched
  running
  success
  failed
  cancelled
}

model Run {
  id                String            @id @default(uuid())
  status            RunStatus         @default(waiting_confirmation)
  draftValue        String
  dispatchedAt      DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  errorSummary      String?
  cancelledAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  projectId         String
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messageId         String?
  message           Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  auditLogs         RoutingAuditLog[]
  artifactVersions  ArtifactVersion[]
  @@index([projectId, status])
  @@index([projectId, createdAt])
}

model RoutingAuditLog {
  id String @id @default(uuid())
  runId String
  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  action String
  actor String
  payload Json?
  createdAt DateTime @default(now())
}

model Artifact {
  id        String   @id @default(uuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  versions  ArtifactVersion[]
}

model ArtifactVersion {
  id         String   @id @default(uuid())
  version    Int
  artifactId String
  artifact   Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  runId      String
  run        Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  sandboxUrl String?
  title      String?
  createdAt  DateTime @default(now())
  files      ArtifactFile[]
  @@unique([artifactId, version])
  @@index([artifactId, createdAt])
}

model ArtifactFile {
  id                String          @id @default(uuid())
  artifactVersionId String
  artifactVersion   ArtifactVersion @relation(fields: [artifactVersionId], references: [id], onDelete: Cascade)
  path              String
  content           String
  @@unique([artifactVersionId, path])
}
